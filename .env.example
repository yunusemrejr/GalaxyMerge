# Galaxy Merge Harness — Environment Variables
# Copy this file to .env and fill in your provider keys.
# NEVER commit .env to git. It is already in .gitignore.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# StreamLake
STREAMLAKE_API_KEY=

# StepFun
STEPFUN_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# GitHub (for repo scanning)
GITHUB_TOKEN=
GH_TOKEN=
