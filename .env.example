# Galaxy Merge Harness — Provider API Keys
# =========================================
# Copy this file to .env (or export the vars directly) and fill in your keys.
# Galaxy Merge reads these environment variables at runtime.
#
#   cp .env.example .env
#   source .env
#   gm
#
# WARNING: .env is in .gitignore — never commit secrets to the public repo.
# If you accidentally commit a secret, rotate it immediately and scrub the
# git history.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google AI / Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# StepFun — https://platform.stepfun.ai
STEPFUN_API_KEY=

# StreamLake / Vanchin — internal
STREAMLAKE_API_KEY=

# MiniMax — https://platform.minimaxi.com
MINIMAX_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NVIDIA NIM — https://build.nvidia.com
NVIDIA_API_KEY=

# Kimi / Moonshot — https://platform.moonshot.cn
KIMI_API_KEY=

# Ollama Cloud — https://cloud.ollama.com
OLLAMA_API_KEY=

# GitHub (for repo scanning) — https://github.com/settings/tokens
GITHUB_TOKEN=
GH_TOKEN=
